{
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "version": "independent",
  "command": {
    "publish": {
      "ignoreChanges": [
        "**/*.md",
        "**/*.yml",
        "**/*.test.js",
        "**/makefile",
        ".*"
      ],
      "verifyAccess": false,
      "verifyRegistry": false
    }
  }
}
